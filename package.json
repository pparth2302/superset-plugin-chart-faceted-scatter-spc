{
  "name": "@pparth2302/superset-plugin-chart-faceted-scatter-spc",
  "version": "0.1.6",
  "description": "Apache Superset 6.0.0 plugin for faceted manufacturing SPC scatter charts built with ECharts.",
  "sideEffects": false,
  "main": "lib/index.js",
  "module": "esm/index.js",
  "types": "lib/index.d.ts",
  "files": [
    "esm",
    "lib"
  ],
  "private": false,
  "scripts": {
    "build": "npm run build-cjs && npm run build-esm && npm run ts-types",
    "build-cjs": "babel src --extensions \".ts,.tsx,.js,.jsx\" --copy-files --out-dir lib",
    "build-clean": "npm run clean && npm run build",
    "build-esm": "node scripts/run-babel-esm.mjs",
    "dev": "node scripts/run-babel-esm.mjs --watch",
    "prebuild": "node scripts/clean.mjs",
    "postbuild": "npm run test",
    "clean": "node scripts/clean.mjs",
    "ts-types": "tsc --build",
    "test": "jest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pparth2302/superset-plugin-chart-faceted-scatter-spc.git"
  },
  "homepage": "https://github.com/pparth2302/superset-plugin-chart-faceted-scatter-spc#readme",
  "bugs": {
    "url": "https://github.com/pparth2302/superset-plugin-chart-faceted-scatter-spc/issues"
  },
  "keywords": [
    "superset",
    "apache-superset",
    "plugin",
    "echarts",
    "scatter",
    "facet",
    "spc",
    "quality"
  ],
  "author": "Parth Patel",
  "license": "Apache-2.0",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "dependencies": {
    "echarts": "^5.6.0"
  },
  "peerDependencies": {
    "@superset-ui/chart-controls": "^0.20.3",
    "@superset-ui/core": "^0.20.4",
    "react": "^17.0.2",
    "react-dom": "^17.0.2"
  },
  "devDependencies": {
    "@airbnb/config-babel": "^2.0.1",
    "@babel/cli": "^7.16.0",
    "@superset-ui/chart-controls": "^0.20.3",
    "@superset-ui/core": "^0.20.4",
    "@types/jest": "^26.0.4",
    "@types/react": "^17.0.89",
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "rimraf": "^3.0.2",
    "typescript": "^4.1.2"
  }
}
